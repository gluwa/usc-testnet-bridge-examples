## These values should not be changed during the course of the tutorials ##
# Source chain key for Sepolia on CC3 Testnet (different from its chain ID, which is 11155111)
# Chain key is the source chain identifier for all USC interactions on Creditcoin
# You can obtain the source chain key through the SupportedChains smart contract deployed on USC Testnet
SOURCE_CHAIN_KEY=1
# Prover API URL for CC3 Devnet
PROVER_API_URL="https://prover.cc3-devnet.creditcoin.network/"
# ERC20 burner contract on Sepolia
SOURCE_CHAIN_CONTRACT_ADDRESS="0x53311D909aC66Fb2a37A90466991B17BFaFB6EBa"
# USC Minter contract on CC3 Devnet
USC_MINTER_CONTRACT_ADDRESS="0x914Cf96BF28b7b4921db27b264ecEd71aC91134E"
# USC Mintable Token contract on CC3 Devnet
USC_MINTABLE_TOKEN="0x9d960f72121189de0ca0bcE0133359a1285a4a7C"
# Creditcoin RPC URL for CC3 Devnet
CREDITCOIN_RPC_URL="https://rpc.cc3-devnet.creditcoin.network"

## These values will get filled as the tutorials are performed ##
