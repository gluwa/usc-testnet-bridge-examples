USC_CUSTOM_MINTER_CONTRACT_ADDRESS=""
# Address of your custom MintableToken
USC_CUSTOM_MINTABLE_TOKEN=""
# Your private key on CC3 Testnet and Sepolia
CREDITCOIN_WALLET_PRIVATE_KEY="0x67f7e8bed880d86d94a3f33c78b15e2fa231e974351e60308edf09dc177d8f6e"

# Address of the custom USC Loan manager contract on CC3 Testnet
